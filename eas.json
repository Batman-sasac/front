{
  "cli": {
    "version": ">= 18.0.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "env":{
        "EXPO_PUBLIC_API_BASE_URL": "https://python-mlt6.onrender.com",
        "EXPO_PUBLIC_KAKAO_REDIRECT_URI": "https://python-mlt6.onrender.com/auth/kakao/mobile",
        "EXPO_PUBLIC_NAVER_REDIRECT_URI": "https://python-mlt6.onrender.com/auth/naver/mobile"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
