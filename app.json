{
  "expo": {
    "name": "Bat",
    "slug": "frontend",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/bat-character.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "buildNumber": "21",
      "supportsTablet": true,
      "bundleIdentifier": "com.batman.bat",
      "userAppleSignIn": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "NSCameraUsageDescription": "이 앱은 학습 자료를 촬영하여 OCR로 텍스트를 인식하고 학습 콘텐츠를 생성하기 위해 카메라 접근 권한을 요청합니다. 예를 들어 사용자는 교재, 필기, 문제집 페이지를 촬영해 학습에 활용할 수 있습니다.",
        "NSPhotoLibraryUsageDescription": "이 앱은 사진 보관함의 학습 자료 이미지를 선택하여 OCR로 텍스트를 인식하고 학습 콘텐츠를 생성하기 위해 사진 접근 권한을 요청합니다. 예를 들어 사용자는 교재, 필기, 문제집 이미지를 불러와 학습에 활용할 수 있습니다.",
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ],
        "LSApplicationQueriesSchemes": [
          "kakaokompassauth",
          "kakaolink",
          "kakaoplus",
          "kakaonavi-sdk"
        ],
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "kakaoe365864e7fe56bb2f65a88afd873b33d"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.batman.bat",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "ios": {
            "useHooks": true
          }
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "e9972864-6164-4023-9020-a4b1f3c766a4"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e9972864-6164-4023-9020-a4b1f3c766a4"
    }
  }
}
